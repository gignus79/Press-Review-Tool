# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
# Dopo logout (es. /dashboard; allineare anche in Clerk Dashboard → Paths)
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/dashboard
# Dashboard Clerk → Configure → Webhooks → Add endpoint:
# Endpoint URL (prod): https://TUO_DOMINIO.vercel.app/api/webhooks/clerk
# Endpoint URL (dev):  https://TUO_NGROK_URL/api/webhooks/clerk
# Events: almeno user.created (e user.updated se sincronizzi il profilo)
CLERK_WEBHOOK_SECRET=whsec_...

# Perplexity (search)
PERPLEXITY_API_KEY=pplx-...

# Anthropic — categorization (optional; billing is via console.anthropic.com API credits, not chat-only plans)
ANTHROPIC_API_KEY=sk-ant-...

# Neon
DATABASE_URL=postgresql://...@...neon.tech/...?sslmode=require

# Security / anti-abuse (Free tier: max distinct identities per IP per month; default 4 if unset/invalid)
FREE_ACCOUNTS_PER_IP_LIMIT=4

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRESSREVIEW_PRO_PRICE_ID=price_...
STRIPE_PRESSREVIEW_BUSINESS_PRICE_ID=price_...

# Feedback → email a developer@toskyrecords.com (opzionale; senza chiave resta solo DB)
# https://resend.com — verifica dominio o usa onboarding@resend.dev in dev
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="Press Review Tool <onboarding@resend.dev>"

# App — URL pubblico (senza slash finale). Serve a link assoluti, OG/Twitter e metadataBase in produzione.
# Esempio produzione: https://press-review-tool.labeltools.toskyrecords.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
